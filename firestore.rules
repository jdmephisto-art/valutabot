rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ValutaBot Security Rules - Final Optimized Version
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Правила для оперативного кэша (get - всем, list - запрещено, запись - авторизованным пользователям)
    match /rates_cache/{id} {
      allow get: if true;
      allow list: if false;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // Правила для истории (get и list - всем для графиков, create и update - только авторизованным сессиям для кэширования)
    match /rates_history/{id} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if false; 
    }

    // Личные данные пользователей
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId);

      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isOwner(userId);
      }
    }

    // Публичные справочники
    match /currencies/{currencyId} {
      allow get, list: if true;
      allow create, update, delete: if false; 
    }

    match /exchange_rates/{exchangeRateId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}
